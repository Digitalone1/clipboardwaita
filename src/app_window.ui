<?xml version="1.0" encoding="UTF-8"?>
<interface domain="clipboardwaita">
    <template class="AppWindow" parent="AdwWindow">
        <property name="title" translatable="yes">Clipboard History</property>

        <property name="content">
            <object class="AdwToolbarView">
                <property name="content">
                    <object class="AdwToastOverlay" id="content_adwtoast_overlay">
                        <property name="child">
                            <object class="GtkOverlay" id="content_overlay">
                                <property name="child">
                                    <object class="AdwClamp">
                                        <property name="maximum-size">900</property>
                                        <property name="tightening-threshold">600</property>

                                        <property name="child">
                                            <object class="GtkScrolledWindow">
                                                <property name="hexpand">1</property>

                                                <child>
                                                    <object class="GtkListBox" id="clipboard_history_listbox">
                                                        <property name="hexpand">1</property>
                                                        <property name="show-separators">1</property>
                                                        <property name="selection-mode">none</property>

                                                        <style>
                                                            <class name="background" />
                                                        </style>

                                                        <child type="placeholder">
                                                            <object class="GtkBox">
                                                                <property name="orientation">vertical</property>

                                                                <child>
                                                                    <object class="AdwStatusPage" id="list_status_page">
                                                                        <property name="vexpand">1</property>
                                                                        <property name="icon-name">edit-paste-symbolic</property>
                                                                        <property name="title" translatable="yes">Empty List</property>

                                                                        <style>
                                                                            <class name="compact" />
                                                                        </style>
                                                                    </object>
                                                                </child>

                                                                <child>
                                                                    <object class="AdwStatusPage" id="search_status_page">
                                                                        <property name="visible">0</property>
                                                                        <property name="vexpand">1</property>
                                                                        <property name="icon-name">system-search-symbolic</property>
                                                                        <property name="title" translatable="yes">No Results Found</property>
                                                                        <property name="description" translatable="yes">Try a different search</property>

                                                                        <style>
                                                                            <class name="compact" />
                                                                        </style>
                                                                    </object>
                                                                </child>
                                                            </object>
                                                        </child>
                                                    </object>
                                                </child>
                                            </object>
                                        </property>
                                    </object>
                                </property>
                            </object>
                        </property>
                    </object>
                </property>

                <child type="top">
                    <object class="AdwHeaderBar">
                        <child type="start">
                            <object class="GtkSwitch" id="clipboard_watcher_switch">
                                <property name="visible" bind-source="selection_mode_toggle_button" bind-property="active" bind-flags="sync-create|invert-boolean" />
                                <property name="tooltip-text" translatable="yes">Enable/disable clipboard tracking</property>
                            </object>
                        </child>

                        <child type="start">
                            <object class="GtkButton" id="remove_selected_items_button">
                                <property name="visible">0</property>
                                <property name="visible" bind-source="selection_mode_toggle_button" bind-property="active" bind-flags="sync-create" />
                                <property name="icon-name">user-trash-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Remove selected entries</property>

                                <style>
                                    <class name="destructive-action" />
                                    <class name="flat" />
                                </style>
                            </object>
                        </child>

                        <child type="start">
                            <object class="GtkButton" id="select_all_items_button">
                                <property name="visible">0</property>
                                <property name="visible" bind-source="selection_mode_toggle_button" bind-property="active" bind-flags="sync-create" />
                                <property name="icon-name">view-list-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Select all entries in the current list</property>
                            </object>
                        </child>

                        <child type="start">
                            <object class="GtkMenuButton">
                                <property name="visible">0</property>
                                <property name="visible" bind-source="selection_mode_toggle_button" bind-property="active" bind-flags="sync-create" />
                                <property name="icon-name">help-about-symbolic</property>
                                <property name="popover">
                                    <object class="GtkPopover">
                                        <property name="child">
                                            <object class="GtkLabel">
                                                <property name="justify">center</property>
                                                <property name="wrap">1</property>
                                                <property name="max-width-chars">36</property>
                                                <property name="label" translatable="yes">Click the row to select an entry. CTRL + double click to unselect and CTRL + up/down key to select multiple entries. Exit the selection mode to unselect all.</property>
                                            </object>
                                        </property>
                                    </object>
                                </property>
                            </object>
                        </child>

                        <child type="end">
                            <object class="GtkMenuButton" id="primary_menu_button">
                                <property name="icon_name">open-menu-symbolic</property>
                                <property name="primary">1</property>
                                <property name="menu_model">primary_menu</property>
                            </object>
                        </child>

                        <child type="end">
                            <object class="GtkToggleButton" id="selection_mode_toggle_button">
                                <property name="icon-name">selection-mode-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Selection mode</property>
                            </object>
                        </child>

                        <child type="end">
                            <object class="GtkToggleButton" id="search_mode_toggle_button">
                                <property name="icon-name">system-search-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Search entries</property>
                            </object>
                        </child>
                    </object>
                </child>

                <child type="top">
                    <object class="AdwClamp">
                        <property name="maximum-size">600</property>
                        <property name="tightening-threshold">300</property>

                        <property name="child">
                            <object class="GtkSearchBar" id="top_search_bar">
                                <property name="margin-start">8</property>
                                <property name="margin-end">8</property>
                                <property name="search-mode-enabled">0</property>

                                <child>
                                    <object class="GtkSearchEntry" id="search_entry">
                                        <property name="hexpand">1</property>
                                        <property name="margin-top">4</property>
                                        <property name="search-delay">200</property>
                                        <property name="placeholder-text" translatable="yes">Type to search entries...</property>
                                    </object>
                                </child>
                            </object>
                        </property>
                    </object>
                </child>

                <child type="bottom">
                    <object class="GtkActionBar" id="footer_mobile">
                        <property name="revealed">0</property>
                        <property name="hexpand">1</property>
                        <property name="margin-start">8</property>
                        <property name="margin-end">8</property>

                        <child type="end">
                            <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="halign">end</property>

                                <child>
                                    <object class="GtkLabel" id="footer_list_size_mobile">
                                        <property name="halign">end</property>
                                        <property name="justify">right</property>
                                        <property name="single-line-mode">1</property>
                                        <property name="ellipsize">end</property>
                                        <property name="label" translatable="yes">Empty list</property>

                                        <style>
                                            <class name="dimmed" />
                                        </style>
                                    </object>
                                </child>

                                <child>
                                    <object class="GtkLabel" id="footer_bg_service_mobile">
                                        <property name="halign">end</property>
                                        <property name="justify">right</property>
                                        <property name="single-line-mode">1</property>
                                        <property name="ellipsize">end</property>
                                        <property name="label" translatable="yes">Background service disabled</property>

                                        <style>
                                            <class name="dimmed" />
                                        </style>
                                    </object>
                                </child>
                            </object>
                        </child>
                    </object>
                </child>

                <child type="bottom">
                    <object class="GtkActionBar" id="footer_desktop">
                        <property name="revealed">1</property>
                        <property name="hexpand">1</property>
                        <property name="margin-top">2</property>
                        <property name="margin-bottom">2</property>
                        <property name="margin-start">8</property>
                        <property name="margin-end">8</property>

                        <child type="start">
                            <object class="GtkLabel" id="footer_list_size">
                                <property name="halign">start</property>
                                <property name="justify">left</property>
                                <property name="single-line-mode">1</property>
                                <property name="ellipsize">end</property>
                                <property name="label" translatable="yes">Empty list</property>

                                <style>
                                    <class name="dimmed" />
                                </style>
                            </object>
                        </child>

                        <child type="end">
                            <object class="GtkLabel" id="footer_bg_service">
                                <property name="halign">end</property>
                                <property name="justify">right</property>
                                <property name="single-line-mode">1</property>
                                <property name="ellipsize">end</property>
                                <property name="label" translatable="yes">Background service disabled</property>

                                <style>
                                    <class name="dimmed" />
                                </style>
                            </object>
                        </child>
                    </object>
                </child>
            </object>
        </property>

        <child>
            <object class="AdwBreakpoint" id="window_breakpoint">
                <condition>max-width: 500sp</condition>
                <setter object="footer_desktop" property="revealed">0</setter>
                <setter object="footer_mobile" property="revealed">1</setter>
            </object>
        </child>
    </template>

    <menu id="primary_menu">
        <section>
            <item>
                <attribute name="label" translatable="yes">_Preferences</attribute>
                <attribute name="action">app.preferences</attribute>
            </item>
            <item>
                <attribute name="label" translatable="yes">_Keyboard shortcuts</attribute>
                <attribute name="action">app.shortcuts</attribute>
            </item>
            <item>
                <attribute name="label" translatable="yes">_Help</attribute>
                <attribute name="action">app.help</attribute>
            </item>
            <item>
                <attribute name="label" translatable="yes">_About Clipboard History</attribute>
                <attribute name="action">app.about</attribute>
            </item>
        </section>
    </menu>

    <object class="AdwDialog" id="first_time_alert">
        <property name="title">Warning</property>
        <property name="can-close">1</property>

        <property name="child">
            <object class="AdwToolbarView">
                <property name="content">
                    <object class="GtkLabel" id="first_time_alert_label">
                        <property name="justify">center</property>
                        <property name="wrap">1</property>
                        <property name="max-width-chars">50</property>
                        <property name="margin-top">4</property>
                        <property name="margin-bottom">4</property>
                        <property name="margin-start">16</property>
                        <property name="margin-end">16</property>
                    </object>
                </property>

                <child type="top">
                    <object class="AdwHeaderBar" />
                </child>

                <child type="bottom">
                    <object class="GtkCheckButton" id="dismiss_first_time_alert_checkbutton">
                        <property name="halign">center</property>
                        <property name="active">0</property>
                        <property name="label" translatable="yes">Do not show anymore</property>
                        <property name="margin-top">12</property>
                        <property name="margin-bottom">12</property>
                        <property name="margin-start">16</property>
                        <property name="margin-end">16</property>
                    </object>
                </child>
            </object>
        </property>
    </object>
</interface>
